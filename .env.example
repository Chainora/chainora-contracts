# Shared RPC configuration
# The JavaScript wizard CLI reads `RPC_URL` from `.env`.
# Keep `ETH_RPC_URL` in sync so other CLI tools can still use the same endpoint by default.
RPC_URL=http://23.94.63.207:8545
ETH_RPC_URL=http://23.94.63.207:8545

# Core signer
# Optional in `.env`: if omitted, the CLI will prompt for PRIVATE_KEY at runtime.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Timelock bootstrap defaults
# `CHAINORA_MULTISIG` falls back to the signer when left blank.
# Role lists are comma-separated addresses with no spaces.
CHAINORA_MULTISIG=
CHAINORA_TIMELOCK_DELAY=0
CHAINORA_PROPOSERS=
CHAINORA_EXECUTORS=
CHAINORA_CANCELLERS=

# Persistent deployed addresses
# The CLI auto-syncs these values after successful deploys, and can optionally sync some of them after admin execute.
CHAINORA_TIMELOCK=
CHAINORA_REGISTRY=
CHAINORA_DEVICE_ADAPTER=
CHAINORA_REPUTATION_ADAPTER=
CHAINORA_POOL_IMPLEMENTATION=
CHAINORA_FACTORY=

# Local-only test stablecoin defaults (`tcUSD`, 18 decimals)
# `CHAINORA_TEST_STABLECOIN` is auto-synced by the CLI after deploying `ChainoraTestUSD`.
CHAINORA_TEST_STABLECOIN=
CHAINORA_TEST_STABLECOIN_OWNER=
CHAINORA_TEST_STABLECOIN_INITIAL_SUPPLY=1000000000000000000000000
