# Core signer
# Deployer private key
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Pool creation defaults
# If your stablecoin has 6 decimals, 100 units = 100000000
# If it has 18 decimals, replace with 100000000000000000000
CHAINORA_CONTRIBUTION_AMOUNT=100000000000000000000
CHAINORA_TARGET_MEMBERS=5
CHAINORA_PERIOD_DURATION=3600
CHAINORA_CONTRIBUTION_WINDOW=1800
CHAINORA_AUCTION_WINDOW=900
CHAINORA_MAX_CYCLES=2
